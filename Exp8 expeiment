<html>
<head>
<script>
function findLargest() {
let num1 = parseInt(prompt("Enter first number:"));
let num2 = parseInt(prompt("Enter second number:"));
let num3 = parseInt(prompt("Enter third number:")); 
let result;
if (num1 === num2 && num2 === num3) {
result = "EQUAL NUMBERS";
} else {
let largest = Math.max(num1, num2, num3);
result = largest + " - LARGER NUMBER";
}
document.getElementById("output").innerText = result;
}
function displayWeekDay() {
let dayNumber = parseInt(prompt("Enter a number (1-7) for the day of the week:"));
let day;
switch(dayNumber) {
case 1: day = "Sunday"; break;
case 2: day = "Monday"; break;
case 3: day = "Tuesday"; break;
case 4: day = "Wednesday"; break;
case 5: day = "Thursday"; break;
case 6: day = "Friday"; break;
case 7: day = "Saturday"; break;
default: day = "Invalid day";
}
document.getElementById("output").innerText = "Day: " + day;
}
function printNumbers() {
let result = "For Loop: ";
for (let i = 1; i <= 10; i++) result += i + " ";
result += "\nWhile Loop: ";
let j = 1;
while (j <= 10) { result += j + " "; j++; }
result += "\nDo-While Loop: ";
let k = 1;
do { result += k + " "; k++; } while (k <= 10);
document.getElementById("output").innerText = result;
}
function printObjectData() {
let person = {name: "Alice", age: 25, city: "New York"};
let result = "For-In Loop: ";
for (let key in person) result += key + "=" + person[key] + " ";
result += "\nFor-Of Loop: ";
let values = Object.values(person);
for (let value of values) result += value + " "; 
document.getElementById("output").innerText = result;
}
function isArmstrong() {
let num = parseInt(prompt("Enter a number:"));
let sum = 0, temp = num;
while (temp > 0) {
let digit = temp % 10;
sum += digit ** 3;
temp = Math.floor(temp / 10);
}
document.getElementById("output").innerText = num === sum ? num + " is an Armstrong 
number" : num + " is NOT an Armstrong number";
}
function calculateDenominations() {
let amount = parseInt(prompt("Enter the amount:"));
let denominations = [100, 50, 10, 5, 2, 1];
let result = "Denominations: ";
for (let denom of denominations) {
let count = Math.floor(amount / denom);
if (count > 0) {
result += count + " - " + denom + "'s, ";
amount %= denom;
}
}
document.getElementById("output").innerText = result;
}
</script>
</head>
<body>
<h2>JavaScript Conditional Statements and Loops</h2>
<button onclick="findLargest()">Find Largest Number</button>
<button onclick="displayWeekDay()">Display Week Day</button>
<button onclick="printNumbers()">Print Numbers (1-10)</button>
<button onclick="printObjectData()">Print Object Data</button>
<button onclick="isArmstrong()">Check Armstrong Number</button>
<button onclick="calculateDenominations()">Calculate Denominations</button>
<p id="output"></p>
</body>
</html>
